# このファイルをコピーして .env を作成してください（.env はコミットしないこと）。
#   Windows PowerShell : Copy-Item .env.example .env
#   macOS / Linux       : cp .env.example .env
#
# ダミー値のみ。実際のパスワードは各自の .env でのみ設定し、Gitへコミットしないこと。

COMPOSE_PROJECT_NAME=urinavi

# --- MySQLコンテナ本体の初期化用（mysqlイメージが参照する） ---
MYSQL_DATABASE=urinavi_test
MYSQL_USER=urinavi
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_root_me
# ホスト側の公開ポート。ローカルに別のMySQLが3306で動いていても衝突しないよう既定は3307。
MYSQL_HOST_PORT=3307

# --- API（Express）コンテナの公開ポート ---
# 既存コード(server.js / customer-web の vite proxy)が既定4000で統一されているため、
# 指示書テンプレの3000ではなく既存の4000を踏襲する。
API_PORT=4000

# --- customer-web（Vite dev server）の公開ポート ---
CUSTOMER_WEB_PORT=5173

# --- APIコンテナからDBへの接続情報。MYSQL_* と値を一致させること ---
DB_HOST=db
DB_PORT=3306
DB_NAME=urinavi_test
DB_USER=urinavi
DB_PASSWORD=change_me

NODE_ENV=development

# customer-web / 将来のadmin-web等、ブラウザから直接APIを叩く際に許可するオリジン(カンマ区切り)。
# 開発時はこれに加えて private LAN (192.168.x.x / 10.x.x.x / 172.16-31.x.x) からのアクセスも
# 自動許可する（スマホ実機確認のため）。本番相当の設定ではこの自動許可は行わないこと。
CORS_ORIGINS=http://localhost:5173

# --- フロントに公開される変数（DBパスワード等の秘密情報を絶対に入れないこと） ---
VITE_API_BASE_URL=/api

# 従業員向けExpoアプリ(urinavi/)からAPIへ接続する場合の例。
# スマホ実機では localhost が使えないため、PCのLAN内IPに置き換えて urinavi/.env 等で設定する。
EXPO_PUBLIC_API_URL=http://192.168.x.x:4000
